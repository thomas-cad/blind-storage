// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  username       String           @unique
  auth_hash      String
  salt_mp        String // salt pour KEK_1 (mot de passe)
  salt_rc        String // salt pour KEK_2 (recovery key)
  pub_key        String           @unique
  priv_key_enc_1 String           @unique
  priv_key_enc_2 String           @unique
  userTree       UserTree?
  files          File[]
  permissions    FilePermission[] @relation("UserPermissions")
  grantedPerms   FilePermission[] @relation("GrantedPermissions")
  editedVersions FileVersion[]
}

model UserTree {
  id                  String @id @default(uuid())
  userId              String @unique
  user                User   @relation(fields: [userId], references: [id])
  encrypted_structure String
  signature           String
}

model File {
  id             String           @id @default(uuid())
  createdAt      DateTime         @default(now())
  cloud_data     Json
  ownerId        String
  owner          User             @relation(fields: [ownerId], references: [id])
  permissions    FilePermission[]
  versions       FileVersion[]
}

model FilePermission {
  id          String         @id @default(uuid())
  fileId      String
  userId      String
  enc_fek     String
  read        Boolean        @default(false)
  write       Boolean        @default(false)
  grantedById String
  grantedAt   DateTime       @default(now())
  file        File           @relation(fields: [fileId], references: [id])
  user        User           @relation("UserPermissions", fields: [userId], references: [id])
  grantedBy   User           @relation("GrantedPermissions", fields: [grantedById], references: [id])

  @@unique([fileId, userId])
}

model FileVersion {
  id         String   @id @default(uuid())
  fileId     String
  version    Int
  createdAt  DateTime @default(now())
  signature  String
  editedById String
  file       File     @relation(fields: [fileId], references: [id])
  editor     User     @relation(fields: [editedById], references: [id])

  @@unique([fileId, version])
}
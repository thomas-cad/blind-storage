// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  username       String           @unique
  auth_hash      String?          // null si auth uniquement via OIDC (sans mot de passe)
  salt_mp        String?
  salt_rc        String?
  pub_key        String           @unique
  priv_key_enc_1 String           @unique
  priv_key_enc_2 String           @unique

  // Auth methods
  totpSecret     String?          // secret TOTP pour OTP (null si non activé)
  totpEnabled    Boolean          @default(false)

  // Relations
  oidcConnections OidcConnection[]
  userTree        UserTree?
  files           File[]
  permissions     FilePermission[] @relation("UserPermissions")
  grantedPerms    FilePermission[] @relation("GrantedPermissions")
  editedVersions  FileVersion[]
}

// Un utilisateur peut avoir plusieurs connexions OIDC (Google, Rezel, etc.)
model OidcConnection {
  id             String    @id @default(uuid())
  userId         String
  provider       OidcProvider
  providerUserId String    // sub claim du token OIDC
  email          String?   // email retourné par le provider

  // Tokens Google Drive (uniquement pour provider = GOOGLE)
  accessToken    String?   // chiffré en base
  refreshToken   String?   // chiffré en base
  tokenExpiresAt DateTime?
  driveScope     Boolean   @default(false) // true si le scope Drive a été accordé

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId]) // un compte provider = un seul lien
  @@unique([userId, provider])         // un user ne peut lier qu'un compte par provider
  @@index([userId])
}

enum OidcProvider {
  GOOGLE
  REZEL
}

model UserTree {
  id                  String @id @default(uuid())
  userId              String @unique
  user                User   @relation(fields: [userId], references: [id])
  encrypted_structure String
  signature           String
}

model File {
  id             String           @id @default(uuid())
  createdAt      DateTime         @default(now())
  cloud_data     Json
  ownerId        String
  owner          User             @relation(fields: [ownerId], references: [id])
  permissions    FilePermission[]
  versions       FileVersion[]
}

model FilePermission {
  id          String         @id @default(uuid())
  fileId      String
  userId      String
  enc_fek     String
  read        Boolean        @default(false)
  write       Boolean        @default(false)
  grantedById String
  grantedAt   DateTime       @default(now())
  file        File           @relation(fields: [fileId], references: [id])
  user        User           @relation("UserPermissions", fields: [userId], references: [id])
  grantedBy   User           @relation("GrantedPermissions", fields: [grantedById], references: [id])

  @@unique([fileId, userId])
}

model FileVersion {
  id         String   @id @default(uuid())
  fileId     String
  version    Int
  createdAt  DateTime @default(now())
  signature  String
  editedById String
  file       File     @relation(fields: [fileId], references: [id])
  editor     User     @relation(fields: [editedById], references: [id])

  @@unique([fileId, version])
}
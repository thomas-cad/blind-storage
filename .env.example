# ─── Google Drive (OAuth2 par utilisateur) ───────────────────────────────────
# Ces credentials identifient VOTRE APPLICATION auprès de Google.
# Chaque utilisateur connectera son propre compte Google via la page de consentement.
# Voir le README pour les instructions de création.

GOOGLE_CLIENT_ID=123456789-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# URL exacte enregistrée dans Google Cloud Console (doit correspondre exactement)
# En développement local :
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ─── Dropbox ─────────────────────────────────────────────────────────────────
# Access token de l'app Dropbox (généré dans le Dropbox App Console).
# Note : ce token est unique pour toute l'application (pas par utilisateur).
# Pour un stockage multi-utilisateurs sur Dropbox, il faudrait implémenter OAuth2 Dropbox.
DROPBOX_ACCESS_TOKEN=sl.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
